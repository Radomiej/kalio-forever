# ─── Kalio — Environment Variables ───────────────────────────────────────────
# Copy to .env and fill in your values. NEVER commit .env with real API keys.

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER=mock to run fully offline (great for dev and tests).
# Supported providers: openai, openrouter, cometapi, ollama, mock

LLM_PROVIDER=mock
LLM_API_KEY=mock
LLM_BASE_URL=mock
LLM_MODEL=mock

# ── OpenAI ────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ── OpenRouter (https://openrouter.ai/keys) ───────────────────────────────────
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-v1-your-key-here
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini

# ── Perplexity ────────────────────────────────────────────────────────────────
# LLM_PROVIDER=perplexity
# LLM_API_KEY=pplx-your-key-here
# LLM_BASE_URL=https://api.perplexity.ai
# LLM_MODEL=sonar-pro

# ── Ollama (local models) ─────────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=3016
NODE_ENV=development
DATABASE_PATH=./data/kalio.db
WORKSPACE_ROOT=./data/workspaces
MEMORY_DB_PATH=./data/memory
CREDENTIALS_MASTER_KEY=replace-with-a-long-random-secret-in-production
CORS_ORIGIN=http://localhost:5188

# ─── Embedding (for Memory / RAG) ─────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Image generation (optional — set LLM_PROVIDER=mock to skip)
# IMAGE_API_KEY=your-image-api-key
# IMAGE_BASE_URL=https://api.openai.com/v1
# IMAGE_MODEL=dall-e-3

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3016
VITE_WS_URL=http://localhost:3016
