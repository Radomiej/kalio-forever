# ─── Kalio v2 — Environment Variables ────────────────────────────────────────
# Skopiuj do .env i uzupełnij wartości. NIGDY nie commituj .env z prawdziwymi kluczami.

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Użyj "mock" (LLM_API_KEY=mock, LLM_BASE_URL=mock, LLM_MODEL=mock)
# żeby uruchomić bez prawdziwego klucza (MockLLMProvider w LLMModule).

# CometAPI (https://cometapi.com) — tani proxy OpenAI-compatible
LLM_API_KEY=your-cometapi-key-here
LLM_BASE_URL=https://api.cometapi.com/v1
LLM_MODEL=gpt-4o-mini

# OpenRouter (https://openrouter.ai/keys)
# LLM_API_KEY=sk-or-v1-your-key-here
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini

# OpenAI
# LLM_API_KEY=sk-your-openai-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Ollama (local)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen3:8b

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=3015
NODE_ENV=development
DATABASE_PATH=./data/kalio.db
WORKSPACE_ROOT=./data/workspaces

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3015
VITE_WS_URL=http://localhost:3015
