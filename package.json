{
  "name": "kalio-forever",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File start-dev.ps1",
    "dev:e2e": "powershell -ExecutionPolicy Bypass -File start-dev.ps1 -UseMockLLM -BackendPort 3316 -FrontendPort 5288",
    "build": "node scripts/run-turbo.mjs run build",
    "typecheck": "node scripts/run-turbo.mjs run typecheck",
    "lint": "node scripts/run-turbo.mjs run lint",
    "test": "node scripts/run-test-gate.mjs",
    "test:e2e": "node scripts/run-turbo.mjs run test:e2e",
    "clean": "node scripts/run-turbo.mjs run clean",
    "audit": "node scripts/code-audit/run-audit.mjs",
    "audit:report": "node scripts/code-audit/run-audit.mjs && node scripts/code-audit/aggregate.mjs"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "patchedDependencies": {
      "@nestjs/cli": "patches/@nestjs__cli.patch"
    }
  }
}
