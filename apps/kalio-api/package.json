{
  "name": "kalio-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "node_modules/.bin/nest start --watch",
    "start": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kalio/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/websockets": "^11.1.19",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "joi": "^17.13.0",
    "nanoid": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.30",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "~5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.1.0"
  }
}
