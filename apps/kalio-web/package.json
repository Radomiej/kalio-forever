{
  "name": "kalio-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "preview": "vite preview --port 5187",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kalio/types": "workspace:*",
    "@kalio/sdk": "workspace:*",
    "axios": "^1.8.0",
    "lucide-react": "^0.513.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^9.0.3",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.1.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "playwright": "^1.52.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.2.3",
    "@tailwindcss/vite": "^4.2.3",
    "daisyui": "^5.0.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.9",
    "vitest": "^3.1.0"
  }
}
